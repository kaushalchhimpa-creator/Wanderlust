<% layout("/layouts/boilerplate") %>

<section class="explore-header">
  <div>
    <p class="section-kicker">Explore stays</p>
    <h1>Find your next stay</h1>
  </div>
  <a href="/listings/new" class="btn primary-action">
    <i class="fa-solid fa-plus"></i>
    Add Listing
  </a>
</section>

<div class="filter-wrapper">
  <div id="filters">
    <div class="filter active-filter">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic cities</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-dungeon"></i></div>
      <p>Castles</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-building-wheat"></i></div>
      <p>Farms</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </div>

    <div class="filter">
      <div><i class="fa-solid fa-landmark-dome"></i></div>
      <p>Domes</p>
    </div>
  </div>

  <div class="tax-toggle">
    <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
      <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" role="switch">
      <label class="form-check-label" for="flexSwitchCheckDefault">Show taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mt-2">
  <% for(let listing of allListening) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link col">
      <article class="card listing-card">
        <div class="listing-media">
          <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=800&q=60' %>" class="card-img-top listing-img" alt="<%= listing.title %>">
          <span class="listing-badge">Guest favorite</span>
        </div>
        <div class="card-body">
          <div class="listing-title-row">
            <b><%= listing.title %></b>
            <span><i class="fa-solid fa-star"></i> 4.8</span>
          </div>
          <div class="listing-place">
            <span><i class="fa-solid fa-location-dot"></i> <%= listing.location || "Location not added" %></span>
            <span><i class="fa-solid fa-globe"></i> <%= listing.country || "Country not added" %></span>
          </div>
          <p class="card-text listing-price">
            &#8377; <%= listing.price.toLocaleString("en-IN") %> <span>/ night</span>
            <i class="tax-info">+18% GST</i>
          </p>
        </div>
      </article>
    </a>
  <% } %>
</div>

<script>
  const taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("change", () => {
    const taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      info.style.display = taxSwitch.checked ? "inline" : "none";
    }
  });
</script>
